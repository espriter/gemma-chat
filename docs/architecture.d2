direction: right

title: {
  label: Gemma Chat Architecture
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# --- Actors ---

user: {
  label: Browser
  shape: person
  style.fill: "#e8f4fd"
}

# --- GPU Desktop (WSL2) ---

gpu: {
  label: GPU Host
  style.fill: "#f5f5f5"
  style.stroke: "#666"
  style.border-radius: 8

  fastapi: {
    label: "FastAPI\n(gemma-chat)\nport 8095"
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: white
  }

  tools: {
    label: "Tool Router\n(tools.py)"
    shape: hexagon
    style.fill: "#FF9800"
    style.font-color: white
  }

  ollama: {
    label: "Ollama\nport 11434"
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: white
  }

  gemma: {
    label: "Gemma 4 E4B\nGPU VRAM"
    shape: cylinder
    style.fill: "#9C27B0"
    style.font-color: white
  }

  ollama -> gemma: inference
}

# --- RPI4 ---

rpi4: {
  label: DB Host
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.border-radius: 8

  postgres: {
    label: "PostgreSQL\nport 5445\nadsb_message"
    shape: cylinder
    style.fill: "#e65100"
    style.font-color: white
  }

  readsb: {
    label: "readsb\n(ADS-B 수신기)"
    shape: rectangle
    style.fill: "#ff8f00"
    style.font-color: white
  }

  readsb -> postgres: "~3M rows/day"
}

# --- Flows ---

# Normal chat flow
user -> gpu.fastapi: "HTTP SSE" {
  style.stroke: "#4CAF50"
}

gpu.fastapi -> gpu.ollama: "1. /api/chat\n+ tool defs" {
  style.stroke: "#2196F3"
}

# Tool calling flow
gpu.ollama -> gpu.fastapi: "2. tool_calls\n(if DB needed)" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}

gpu.fastapi -> gpu.tools: "3. execute" {
  style.stroke: "#FF9800"
}

gpu.tools -> rpi4.postgres: "4. SELECT\n(read-only)" {
  style.stroke: "#e65100"
}

rpi4.postgres -> gpu.tools: "5. result" {
  style.stroke: "#e65100"
  style.stroke-dash: 3
}

gpu.tools -> gpu.fastapi: "6. tool result" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}

gpu.fastapi -> gpu.ollama: "7. messages\n+ tool result" {
  style.stroke: "#2196F3"
  style.stroke-dash: 3
}

gpu.ollama -> gpu.fastapi: "8. final answer\n(streaming)" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
