direction: right

title: {
  label: ADS-B Chat Architecture
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# --- Actors ---

user: {
  label: Browser
  shape: person
  style.fill: "#e8f4fd"
}

cloudflare: {
  label: "Cloudflare\nadsb.espriter.net"
  shape: cloud
  style.fill: "#f0f0f0"
  style.stroke: "#f6821f"
}

# --- MiniPC ---

minipc: {
  label: "MiniPC (항상 ON)"
  style.fill: "#e8f5e9"
  style.stroke: "#2e7d32"
  style.border-radius: 8

  fastapi: {
    label: "FastAPI\n(gemma-chat)\nport 8095"
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: white
  }

  tools: {
    label: "Tool Router\n(tools.py)\n8 tools"
    shape: hexagon
    style.fill: "#FF9800"
    style.font-color: white
  }

  enrich: {
    label: "Enrich API\nhexdb.io\nNominatim"
    shape: hexagon
    style.fill: "#FF9800"
    style.font-color: white
  }

  ollama_local: {
    label: "Ollama Local\nqwen2.5:1.5b\n(fallback)"
    shape: rectangle
    style.fill: "#78909C"
    style.font-color: white
  }

  tunnel: {
    label: "SSH Tunnel\n:11435→:11434"
    shape: diamond
    style.fill: "#455A64"
    style.font-color: white
  }
}

# --- GPU Desktop ---

gpu: {
  label: "GPU Desktop (WOL ON/OFF)"
  style.fill: "#e3f2fd"
  style.stroke: "#1565c0"
  style.border-radius: 8

  ollama_gpu: {
    label: "Ollama\ngemma4:e4b-it-q8_0\nRTX 5070 Ti"
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: white
  }

  note: {
    label: "모델 서빙만\n서비스 코드 없음"
    shape: text
    style.font-size: 12
    style.font-color: "#666"
    style.italic: true
  }
}

# --- RPI4 ---

rpi4: {
  label: "RPI4 (DB Host)"
  style.fill: "#fff3e0"
  style.stroke: "#e65100"
  style.border-radius: 8

  postgres: {
    label: "PostgreSQL\nport 5445\nadsb_message"
    shape: cylinder
    style.fill: "#e65100"
    style.font-color: white
  }
}

# --- External APIs ---

external: {
  label: "External APIs"
  style.fill: "#fce4ec"
  style.stroke: "#c62828"
  style.border-radius: 8

  hexdb: {
    label: "hexdb.io\n(aircraft info)"
    shape: rectangle
    style.fill: "#ef5350"
    style.font-color: white
  }

  wttr: {
    label: "wttr.in\n(weather)"
    shape: rectangle
    style.fill: "#ef5350"
    style.font-color: white
  }

  nominatim: {
    label: "Nominatim\n(geocoding)"
    shape: rectangle
    style.fill: "#ef5350"
    style.font-color: white
  }
}

# --- Flows ---

# User → Cloudflare → MiniPC
user -> cloudflare: "HTTPS" {
  style.stroke: "#f6821f"
}

cloudflare -> minipc.fastapi: "tunnel" {
  style.stroke: "#f6821f"
}

# Direct access
user -> minipc.fastapi: "HTTP :8095\n(내부)" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}

# Quickstart flow (no LLM)
minipc.fastapi -> minipc.tools: "/api/tool\n(quickstart)" {
  style.stroke: "#FF9800"
}

minipc.tools -> rpi4.postgres: "SELECT\n(read-only)" {
  style.stroke: "#e65100"
}

# Enrich flow
minipc.fastapi -> minipc.enrich: "/api/enrich" {
  style.stroke: "#FF9800"
}

minipc.enrich -> external.hexdb: "aircraft lookup" {
  style.stroke: "#c62828"
}

minipc.enrich -> external.nominatim: "reverse geocode" {
  style.stroke: "#c62828"
}

# LLM flow — GPU first
minipc.fastapi -> minipc.tunnel: "/api/chat\n(GPU 우선)" {
  style.stroke: "#2196F3"
}

minipc.tunnel -> gpu.ollama_gpu: "SSH tunnel" {
  style.stroke: "#2196F3"
}

# LLM fallback — Local
minipc.fastapi -> minipc.ollama_local: "/api/chat\n(fallback)" {
  style.stroke: "#78909C"
  style.stroke-dash: 3
}

# Weather
minipc.tools -> external.wttr: "weather" {
  style.stroke: "#c62828"
}
