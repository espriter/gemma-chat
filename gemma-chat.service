[Unit]
Description=Gemma Chat Web UI (FastAPI + Ollama)
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=your-user
WorkingDirectory=/srv/gemma-chat
EnvironmentFile=/srv/gemma-chat/.env
ExecStart=/srv/gemma-chat/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8095
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
